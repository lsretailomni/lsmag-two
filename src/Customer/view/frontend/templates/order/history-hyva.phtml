        <script>
            function orderHistory(config) {
                return {
                    allOrders: config.orders || [],
                    resultsPerPage: config.resultsPerPage || 10,
                    allowReorder: config.allowReorder || false,
                    cancelEnabled: config.cancelEnabled || false,
                    extraAliases: config.extraAliases || [],
                    icons: config.icons || {},

                    searchColumn: 'documentId',
                    searchText: '',
                    filters: {
                        documentId: '',
                        date: '',
                        shipTo: '',
                        storeName: '',
                        status: ''
                    },

                    sortColumn: 'date',
                    sortDirection: 'desc',

                    pages: [],
                    visibleRows: [],
                    displayPagination: false,
                    hidePreviousButton: true,
                    hideNextButton: true,
                    isActive: 1,

                    init() {
                        this.buildPages(this.allOrders.length)
                        this.activePage(1)
                    },

                    sortBy(column) {
                        if (this.sortColumn === column) {
                            this.sortDirection = this.sortDirection === 'asc' ? 'desc' : 'asc'
                        } else {
                            this.sortColumn = column
                            this.sortDirection = 'asc'
                        }
                        this.$nextTick(() => {
                            this.buildPages(this.filteredOrders().length)
                            this.activePage(1)
                        })
                    },

                    sortIcon(column) {
                        if (this.sortColumn !== column) return this.icons.neutral
                        return this.sortDirection === 'asc' ? this.icons.asc : this.icons.desc
                    },

                    filteredOrders() {
                        const filtered = this.allOrders.filter(order => {
                            return (
                                (!this.filters.documentId || order.documentId.toLowerCase().includes(this.filters.documentId.toLowerCase())) &&
                                (!this.filters.date || order.date.includes(this.filters.date)) &&
                                (!this.filters.shipTo || order.shipTo.toLowerCase().includes(this.filters.shipTo.toLowerCase())) &&
                                (!this.filters.storeName || order.storeName.toLowerCase().includes(this.filters.storeName.toLowerCase())) &&
                                (!this.filters.status || order.status.toLowerCase().includes(this.filters.status.toLowerCase()))
                            )
                        })

                        const dir = this.sortDirection === 'asc' ? 1 : -1
                        const col = this.sortColumn

                        return filtered.sort((a, b) => {
                            if (col === 'date') {
                                return ((a.dateTimestamp || 0) - (b.dateTimestamp || 0)) * dir
                            }
                            if (col === 'total') {
                                const numA = parseFloat(String(a.total).replace(/[^0-9.-]/g, '')) || 0
                                const numB = parseFloat(String(b.total).replace(/[^0-9.-]/g, '')) || 0
                                return (numA - numB) * dir
                            }
                            return String(a[col] ?? '').localeCompare(String(b[col] ?? '')) * dir
                        })
                    },

                    updateFilter() {
                        Object.keys(this.filters).forEach(k => this.filters[k] = '')
                        this.filters[this.searchColumn] = this.searchText
                        this.$nextTick(() => {
                            this.buildPages(this.filteredOrders().length)
                            this.activePage(1)
                        })
                    },

                    buildPages(totalItems) {
                        this.pages = []
                        const totalPages = Math.ceil(totalItems / this.resultsPerPage)
                        if (totalPages > 1) {
                            this.displayPagination = true
                            for (let i = 1; i <= totalPages; i++) this.pages.push(i)
                            this.hideNextButton = false
                        } else {
                            this.displayPagination = false
                        }
                    },

                    activePage(page) {
                        this.isActive = page
                        const filtered = this.filteredOrders()
                        const end = this.resultsPerPage * page
                        const start = end - this.resultsPerPage
                        this.visibleRows = filtered
                            .map((_, i) => i)
                            .filter(i => i >= start && i < end)
                        this.hidePreviousButton = page === 1
                        this.hideNextButton = page === this.pages.length || this.pages.length === 0
                    },

                    toPreviousPage() {
                        if (this.isActive > 1) this.activePage(this.isActive - 1)
                    },

                    toNextPage() {
                        if (this.isActive < this.pages.length) this.activePage(this.isActive + 1)
                    },

                    showAllItems() {
                        this.visibleRows = this.filteredOrders().map((_, i) => i)
                        this.displayPagination = false
                    },

                    startEntry() {
                        if (!this.filteredOrders().length) return 0
                        if (!this.displayPagination) return 1
                        return ((this.isActive - 1) * this.resultsPerPage) + 1
                    },

                    endEntry() {
                        const total = this.filteredOrders().length
                        if (!this.displayPagination) return total
                        const end = this.isActive * this.resultsPerPage
                        return end > total ? total : end
                    }
                }
            }

            window.addEventListener('alpine:init', () => Alpine.data('orderHistory', orderHistory), {once: true})
        </script>

