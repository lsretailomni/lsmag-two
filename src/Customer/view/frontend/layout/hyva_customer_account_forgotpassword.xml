<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="forgotPassword">
            <action method="setTemplate">
                <argument name="template" xsi:type="string">Magento_Customer::form/forgotpassword.phtml</argument>
            </action>
        </referenceBlock>
        <referenceContainer name="form.additional.info">
            <block class="Magento\Captcha\Block\Captcha\DefaultCaptcha"
                   name="ls.captcha.forgotpassword"
                   template="Ls_Customer::form/captcha.phtml"
                   after="-"
                   cacheable="false">
                <action method="setFormId">
                    <argument name="formId" xsi:type="string">user_forgotpassword</argument>
                </action>
                <action method="setImgWidth">
                    <argument name="width" xsi:type="string">230</argument>
                </action>
                <action method="setImgHeight">
                    <argument name="height" xsi:type="string">50</argument>
                </action>
            </block>
        </referenceContainer>
    </body>
</page>

