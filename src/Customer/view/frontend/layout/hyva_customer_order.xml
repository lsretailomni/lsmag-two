<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="content">
            <referenceBlock name="sales.order.items.renderers.default" template="Ls_Customer::order/item/renderer/default-hyva.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">Ls\Customer\ViewModel\ItemRenderer</argument>
                </arguments>
            </referenceBlock>
            <referenceBlock name="sales.order.items.renderers.bundle" template="Ls_Customer::order/item/renderer/bundle.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">Ls\Customer\ViewModel\ItemRenderer</argument>
                </arguments>
            </referenceBlock>
        </referenceContainer>
    </body>
</page>
