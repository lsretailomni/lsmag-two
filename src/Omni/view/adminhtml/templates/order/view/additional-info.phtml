<?php
/**
 * @var \Magento\Sales\Block\Adminhtml\Order\View\Info $block
 */
$order = $block->getOrder();
?>
<?php if (!empty($order->getDocumentId())) : ?>
    <tr>
        <th><?= $block->escapeHtml(__('Ls Central Order Reference ID:')) ?></th>
        <td><?= $block->escapeHtml($order->getDocumentId()) ?></td>
    </tr>
<?php endif; ?>
<?php if ($order->getLsPointsEarn() > 0) : ?>
    <tr>
        <th><?= $block->escapeHtml(__('Loyalty Points Earned')) ?></th>
        <td><span id="order_status"><?= $block->escapeHtml($order->getLsPointsEarn()) ?></span></td>
    </tr>
<?php endif; ?>
<?php if (!empty($order->getCouponCode())) : ?>
    <tr>
        <th><?= $block->escapeHtml(__('Coupon Code Redeemed')) ?></th>
        <td><span id="order_status"><?= $block->escapeHtml($order->getCouponCode()) ?></span></td>
    </tr>
<?php endif; ?>
<?php
$posEntries = json_decode((string)$order->getLsPosDataEntries(), true) ?? [];
if (!empty($posEntries)):
    foreach ($posEntries as $entry):
        $entryLabel = ($entry['entry_type'] ?? '') . ' - ' . ($entry['entry_no'] ?? '');
        $entryAmt   = isset($entry['amount']) ? $order->formatPriceTxt(-(float)$entry['amount']) : '';
?>
    <tr>
        <th><?= $block->escapeHtml(__('%1 Redeemed', $entry['entry_type'] ?? __('POS Entry'))) ?></th>
        <td><?= $block->escapeHtml($entryLabel) ?><?php if ($entryAmt): ?> (<?= $block->escapeHtml($entryAmt) ?>)<?php endif; ?></td>
    </tr>
<?php
    endforeach;
elseif (!empty($order->getLsGiftCardNo())):
?>
    <tr>
        <th><?= $block->escapeHtml(__('Gift Card Code')) ?></th>
        <td><?= $block->escapeHtml($order->getLsGiftCardNo()) ?></td>
    </tr>
<?php endif; ?>
