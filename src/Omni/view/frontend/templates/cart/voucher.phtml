                                <input class="action applyvoucher primary" type="submit"
                                       value="<?= __('Apply') ?>"></input>
                            <?php else: ?>
                                <input class="action applyvoucher primary" type="submit"
                                       value="<?= __('Update') ?>"></input>
                                <input type="submit" class="action cancelvoucher primary"
                                       value="<?= __('Cancel') ?>"></input>
                            <?php endif; ?>
                        </div>
                    </div>
                </div>
            </form>
        </div>
