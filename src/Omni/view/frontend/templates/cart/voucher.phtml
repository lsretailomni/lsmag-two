                                       required="required"/>
                            </div>
                        </div>
                    <?php endif; ?>
                    <div class="field voucher-amount-field">
                        <div class="control">
                            <input type="number" min="0" class="input-text" id="voucheramount" name="voucheramount"
                                   placeholder="Amount to Use" value="<?= $block->getVoucherAmountUsed() ?>"
